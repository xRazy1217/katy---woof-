# ========================================
# Katy & Woof - Configuración de Base de Datos
# ========================================
# 
# IMPORTANTE: Cambia estos valores con las credenciales 
# de tu hosting antes de subir este archivo
#
# Este archivo NO debe ser accesible públicamente.
# Asegúrate de que esté protegido por .htaccess
# ========================================

# Host de la base de datos (generalmente 'localhost')
DB_HOST=localhost

# Nombre de la base de datos
DB_NAME=dbyh6du0yfle1i

# Usuario de la base de datos
DB_USER=uiuxyllculkca

# Contraseña de la base de datos
DB_PASS=l2k13l3~1@&s

# ========================================
# Configuración de Seguridad
# ========================================

# Clave de autenticación del panel admin (cambia esto por seguridad)
ADMIN_AUTH_KEY=Asesor25

# ========================================
# Configuración de E-commerce (Opcional)
# ========================================

# API Key de Flow (procesador de pagos chileno)
# FLOW_API_KEY=tu_api_key_aqui
# FLOW_SECRET_KEY=tu_secret_key_aqui
# FLOW_SANDBOX=true

# ========================================
# Configuración de Entorno
# ========================================

# Entorno: 'production' o 'development'
APP_ENV=production

# Mostrar errores PHP (solo en development)
DISPLAY_ERRORS=false

# ========================================
# NOTAS DE CONFIGURACIÓN
# ========================================
# 
# 1. Obtén las credenciales de tu hosting desde el panel de control
#    (generalmente cPanel, Plesk, o similar)
# 
# 2. En cPanel busca "MySQL Databases" o "Bases de datos MySQL"
# 
# 3. Si no tienes una base de datos creada:
#    - Crea una nueva base de datos
#    - Crea un usuario de base de datos
#    - Asigna el usuario a la base de datos con todos los privilegios
# 
# 4. Después de subir este archivo, importa la estructura:
#    - Accede a phpMyAdmin desde tu hosting
#    - Selecciona la base de datos
#    - Importa el archivo: INIT_SCHEMA_SYSTEM.sql
#    - Luego importa (opcional): INIT_ECOMMERCE_SCHEMA.sql
# 
# 5. Para mejorar la seguridad:
#    - Cambia ADMIN_AUTH_KEY por una clave única
#    - Actualiza la clave en admin-ui.js también
# 
# ========================================
